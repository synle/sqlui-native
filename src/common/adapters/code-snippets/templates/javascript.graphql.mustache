// Using the Fetch API (built-in)
async function _doWork() {
  const endpoint = '{{{endpoint}}}';
  const query = `{{{query}}}`;
  {{#hasVariables}}
  const variables = {{{variablesJson}}};
  {{/hasVariables}}
  {{#operationName}}
  const operationName = '{{{operationName}}}';
  {{/operationName}}

  try {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {{{headersJson}}},
      body: JSON.stringify({
        query,
        {{#hasVariables}}
        variables,
        {{/hasVariables}}
        {{#operationName}}
        operationName,
        {{/operationName}}
      }),
    });

    const result = await response.json();

    if (result.errors) {
      console.error('GraphQL Errors:', JSON.stringify(result.errors, null, 2));
    }

    if (result.data) {
      console.log('Data:', JSON.stringify(result.data, null, 2));
    }
  } catch (err) {
    console.error('Request failed:', err);
  }
}

_doWork();
