{
  "name": "sqlui-native",
  "version": "2.76.24",
  "engine": "Tauri + Node Sidecar",
  "private": true,
  "description": "A minimal native desktop client for most databases supporting MySQL, MariaDB, MS SQL Server, PostgreSQL, SQLite, Cassandra, MongoDB and Redis.",
  "homepage": "./",
  "scripts": {
    "### Cleanup & Maintenance ###": "##################################################################################",
    "clean": "rm -rf build src/package.json ./dist/*",
    "cleanSnapshot": "rm -rf src/common/adapters/__snapshots__/ src/common/adapters/BaseDataAdapter/__snapshots__/ && npm run test-ci -- --update",
    "format": "prettier --write --cache --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:ci": "prettier --write --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:check": "prettier --check --cache --ignore-unknown --print-width 140 .",
    "lint": "eslint --fix --ext .tsx --ext .ts src",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "### Build Lifecycle ###": "##################################################################################",
    "prebuild": "node scripts/prebuild.js",
    "build": "vite build --config vite.frontend.config.ts",
    "postbuild": "npm run build-server",
    "build-server": "vite build --config vite.sqlui-server.config.ts",
    "build-server-sidecar": "vite build --config vite.sqlui-server.sidecar.config.ts",
    "build:tauri": "cross-env-shell NODE_OPTIONS=--max-old-space-size=8192 \"npm run prebuild && npm run build && npm run build-server-sidecar && node scripts/download-node.js && node scripts/prepare-sidecar.js\"",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "### Development & Execution ###": "##################################################################################",
    "predev": "node scripts/prebuild.js",
    "dev": "concurrently \"npm run dev-server\" \"npm run start-webapp\"",
    "start": "npm run tauri:dev",
    "start-webapp": "cross-env ENV_TYPE='browser' vite --config vite.frontend.config.ts --strictPort",
    "prestart-server": "npm run build-server",
    "start-server": "node build/sqlui-server.js",
    "dev-server": "concurrently \"vite build --config vite.sqlui-server.config.ts --watch\" \"nodemon --watch build/sqlui-server.js --delay 1 -- build/sqlui-server.js\"",
    "### Validation ###": "##################################################################################",
    "validate": "npm run lint && npm run typecheck && npm run test-ci && npm run format && npm run test-e2e && npm run test-smoke && npm run test-integration",
    "### Testing ###": "##################################################################################",
    "pretest": "npm run build",
    "test": "vitest --watch",
    "pretest-ci": "npm run pretest",
    "test-ci": "vitest run",
    "test-integration": "vitest run --config vitest.integration.config.ts",
    "start-e2e": "concurrently \"node build/sqlui-server.js\" \"vite preview --config vite.frontend.config.ts --strictPort\"",
    "test-e2e": "npx playwright test",
    "test-smoke": "npx playwright test --config playwright.smoke.config.ts",
    "### Distribution & Packaging ###": "##################################################################################",
    "dist": "npm run tauri:build"
  },
  "repository": "https://github.com/synle/sqlui-native",
  "keywords": [
    "Tauri",
    "SQL",
    "Native Desktop Application",
    "MySQL",
    "MariaDB",
    "Microsoft",
    "PostgreSQL",
    "SQLite",
    "Cassandra"
  ],
  "license": "MIT",
  "author": {
    "name": "Sy Le",
    "email": "le.nguyen.sy@gmail.com"
  },
  "dependencies": {
    "@azure/cosmos": "^3.17.1",
    "@azure/data-tables": "^13.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@testing-library/dom": "^10.4.1",
    "@xyflow/react": "^12.10.2",
    "cassandra-driver": "^3.6.0",
    "connection-string-parser": "^1.0.4",
    "fuzzysort": "^3.1.0",
    "html-to-image": "^1.11.13",
    "js-beautify": "^1.15.4",
    "jsforce": "^3.10.14",
    "json-2-csv": "^5.5.10",
    "lodash.set": "^4.3.2",
    "monaco-editor": "^0.55.1",
    "mongodb": "^4.10.0",
    "mustache": "^4.2.0",
    "mysql2": "^3.22.0",
    "pg": "^8.18.0",
    "qs": "^6.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "redis": "^4.3.1",
    "sql-formatter": "^15.7.3",
    "tedious": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/cassandra-driver": "^3.6.0",
    "@types/js-beautify": "^1.13.3",
    "@types/mustache": "^4.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^0.34.6",
    "body-parser": "^1.20.0",
    "concurrently": "^7.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^4.18.1",
    "jsdom": "^24.1.3",
    "multer": "^1.4.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "supertest": "^6.3.3",
    "typescript": "~5.8",
    "vite": "^6.4.2",
    "vitest": "^0.34.6"
  }
}
