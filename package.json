{
  "name": "sqlui-native",
  "version": "1.66.2",
  "private": true,
  "description": "A minimal native desktop client for most databases supporting MySQL, MariaDB, MS SQL Server, PostgresSQL, SQLite, Cassandra, MongoDB and Redis.",
  "homepage": "./",
  "build": {
    "extends": null,
    "appId": "io.synle.github.sqlui-native",
    "files": [
      "**/*.icns",
      "**/*.ico",
      "**/*.jpg",
      "**/*.png",
      "*.css",
      "*.js",
      "*.json",
      "static/**/*",
      "appx/**/*",
      "assets/**/*",
      "index.html",
      "vs/**/*",
      "!src/**/*",
      "!public/**/*",
      "!typings/**/*",
      "!scripts/**/*",
      "!mocked-server.js",
      "!robots.txt"
    ],
    "win": {
      "icon": "build/logo512.png",
      "artifactName": "${name}-${arch}.${ext}"
    },
    "appx": {
      "publisherDisplayName": "Sy Le",
      "applicationId": "sqluiNative"
    },
    "mac": {
      "icon": "build/logo512.png",
      "artifactName": "${name}-${arch}.${ext}"
    },
    "linux": {
      "synopsis": "sqlui-native - A minimal native desktop client for most databases supporting MySQL, MariaDB, MS SQL Server, PostgresSQL, SQLite, Cassandra, MongoDB and Redis.",
      "icon": "build/logo256.icns",
      "category": "Development",
      "artifactName": "${name}.${ext}",
      "target": [
        "deb",
        "rpm",
        "snap",
        "pacman"
      ]
    }
  },
  "main": "main.js",
  "scripts": {
    "### Cleanup & Maintenance ###": "##################################################################################",
    "clean": "rm -rf build public/vs src/package.json ./dist/*",
    "cleanSnapshot": "rm -rf src/common/adapters/__snapshots__/ src/common/adapters/BaseDataAdapter/__snapshots__/ && npm run test-ci -- --update",
    "format": "prettier --write --cache --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:ci": "prettier --write --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:check": "prettier --check --cache --ignore-unknown --print-width 140 .",
    "lint": "eslint --fix --ext .tsx --ext .ts src",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "### Build Lifecycle ###": "##################################################################################",
    "prebuild": "node scripts/prebuild.js",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --config vite.frontend.config.ts",
    "postbuild": "concurrently \"npm run build-electron\" \"npm run build-mocked-server\"",
    "build-electron": "vite build --config vite.electron.config.ts",
    "build-mocked-server": "vite build --config vite.mocked-server.config.ts",
    "### Development & Execution ###": "##################################################################################",
    "predev": "node scripts/prebuild.js",
    "dev": "concurrently \"npm run dev-mocked-server\" \"npm run start-webapp\"",
    "prestart": "npm run build",
    "start": "npm run start-electron",
    "start-electron": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ENV_TYPE='electron-dev' electron build/main.js",
    "start-electron-dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ENV_TYPE='electron-dev' VITE_DEV_SERVER_URL='http://localhost:3000' electron build/main.js",
    "prestart-dev": "npm run prebuild && npm run build-electron",
    "start-dev": "concurrently \"npm run start-webapp\" \"sleep 3 && npm run start-electron-dev\"",
    "start-webapp": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ENV_TYPE='mocked-server' vite --config vite.frontend.config.ts --strictPort",
    "prestart-mocked-server": "npm run build-mocked-server",
    "start-mocked-server": "cross-env NODE_OPTIONS='--max-old-space-size=4096' node build/mocked-server.js",
    "dev-mocked-server": "concurrently \"vite build --config vite.mocked-server.config.ts --watch\" \"nodemon --watch build/mocked-server.js --delay 1 -- build/mocked-server.js\"",
    "### Testing ###": "##################################################################################",
    "pretest": "npm run build",
    "test": "vitest --watch",
    "pretest-ci": "npm run pretest",
    "test-ci": "vitest run",
    "test-integration": "vitest run --config vitest.integration.config.ts",
    "### Distribution & Packaging ###": "##################################################################################",
    "version-stamp:draft": "npm version prepatch --no-git-tag-version --preid=beta-$(date +%Y%m%d%H%M%S)",
    "version-stamp:release": "npm version patch --no-git-tag-version",
    "dist": "electron-builder build --publish=never",
    "dist-win-x64-exe": "electron-builder build --publish=never --win --x64",
    "dist-win-x64-appx": "electron-builder build --publish=never --win appx",
    "dist-win-arm64": "electron-builder build --publish=never --win --arm64 --config.npmRebuild=false",
    "dist-macos-x64": "electron-builder build --publish=never --mac --x64",
    "dist-macos-arm64": "electron-builder build --publish=never --mac --arm64",
    "dist-linux-appimage": "electron-builder build --publish=never --linux AppImage"
  },
  "repository": "https://github.com/synle/sqlui-native",
  "keywords": [
    "Electron",
    "SQL",
    "Native Desktop Application",
    "MySQL",
    "MariaDB",
    "Microsoft",
    "PostgresSQL",
    "SQLite",
    "Cassandra"
  ],
  "license": "MIT",
  "author": {
    "name": "Sy Le",
    "email": "le.nguyen.sy@gmail.com"
  },
  "dependencies": {
    "@azure/cosmos": "^3.17.1",
    "@azure/data-tables": "^13.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.8.2",
    "@mui/lab": "^5.0.0-alpha.100",
    "@mui/material": "^5.10.8",
    "@tanstack/react-query": "^4.43.0",
    "@tanstack/react-query-devtools": "^4.43.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@xyflow/react": "^12.10.1",
    "cassandra-driver": "^3.6.0",
    "connection-string-parser": "^1.0.4",
    "fuzzysort": "^1.2.1",
    "html-to-image": "^1.10.2",
    "js-beautify": "^1.14.3",
    "jsforce": "^3.10.14",
    "json-2-csv": "^3.17.1",
    "lodash.get": "^4.4.2",
    "lodash.set": "^4.3.2",
    "monaco-editor": "^0.32.1",
    "mongodb": "^4.10.0",
    "mustache": "^4.2.0",
    "mysql2": "^2.3.3",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "qs": "^6.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.2.2",
    "redis": "^4.3.1",
    "sequelize": "^6.37.7",
    "sql-formatter": "^4.0.2",
    "sqlite3": "^5.1.7",
    "tedious": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/cassandra-driver": "^3.6.0",
    "@types/js-beautify": "^1.13.3",
    "@types/mustache": "^4.2.6",
    "@types/react": "^18.0.9",
    "@types/react-dom": "^18.0.3",
    "@types/redis": "^4.0.11",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^0.34.6",
    "body-parser": "^1.20.0",
    "concurrently": "^7.4.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^4.18.1",
    "jsdom": "^24.1.3",
    "multer": "^1.4.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sass": "^1.62.1",
    "supertest": "^6.3.3",
    "typescript": "^4.9.5",
    "vite": "^6.4.1",
    "vitest": "^0.34.6"
  }
}
