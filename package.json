{
  "name": "sqlui-native",
  "version": "3.76.4",
  "engine": "Tauri + Rust",
  "private": true,
  "description": "A cross-platform Tauri desktop client for SQL/NoSQL databases and REST APIs supporting MySQL, MariaDB, MS SQL Server, PostgreSQL, SQLite, Cassandra, MongoDB, Redis, Azure CosmosDB, Azure Table Storage, Salesforce, and REST/GraphQL.",
  "homepage": "./",
  "main": "main.js",
  "scripts": {
    "### Cleanup & Maintenance ###": "##################################################################################",
    "clean": "rm -rf build public/vs src/package.json ./dist/*",
    "cleanSnapshot": "rm -rf src/common/adapters/__snapshots__/ src/common/adapters/BaseDataAdapter/__snapshots__/ && npm run test-ci -- --update",
    "format": "prettier --write --cache --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:ci": "prettier --write --ignore-unknown --no-error-on-unmatched-pattern --print-width 140 .",
    "format:check": "prettier --check --cache --ignore-unknown --print-width 140 .",
    "lint": "eslint --fix --ext .tsx --ext .ts src",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit",
    "### Build Lifecycle ###": "##################################################################################",
    "prebuild": "node scripts/prebuild.js",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build --config vite.frontend.config.ts",
    "### Development & Execution ###": "##################################################################################",
    "predev": "node scripts/prebuild.js",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' vite --config vite.frontend.config.ts --strictPort",
    "start": "npm run tauri:dev",
    "### Validation ###": "##################################################################################",
    "validate": "npm run lint && npm run typecheck && npm run test-ci && npm run format && npm run check-rust && npm run test-rust",
    "### Testing ###": "##################################################################################",
    "pretest": "npm run build",
    "test": "vitest --watch",
    "pretest-ci": "npm run pretest",
    "test-ci": "vitest run",
    "test-e2e": "npx playwright test",
    "test-smoke": "npx playwright test --config playwright.smoke.config.ts",
    "### Tauri ###": "##################################################################################",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check-rust": "cd src-tauri && cargo check",
    "test-rust": "cd src-tauri && cargo test",
    "### Distribution & Packaging ###": "##################################################################################",
    "dist": "tauri build",
    "dist-macos-x64": "tauri build --target x86_64-apple-darwin",
    "dist-macos-arm64": "tauri build --target aarch64-apple-darwin",
    "dist-linux-x64": "tauri build --target x86_64-unknown-linux-gnu",
    "dist-windows-x64": "tauri build --target x86_64-pc-windows-msvc"
  },
  "repository": "https://github.com/synle/sqlui-native",
  "keywords": [
    "Tauri",
    "SQL",
    "Native Desktop Application",
    "MySQL",
    "MariaDB",
    "PostgreSQL",
    "SQLite",
    "Cassandra",
    "MongoDB",
    "Redis",
    "REST API"
  ],
  "license": "MIT",
  "author": {
    "name": "Sy Le",
    "email": "le.nguyen.sy@gmail.com"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/lab": "^9.0.0-beta.2",
    "@mui/material": "^9.0.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@testing-library/dom": "^10.4.1",
    "@xyflow/react": "^12.10.2",
    "fuzzysort": "^3.1.0",
    "html-to-image": "^1.11.13",
    "js-beautify": "^1.15.4",
    "connection-string-parser": "^1.0.4",
    "json-2-csv": "^5.5.10",
    "lodash.set": "^4.3.2",
    "monaco-editor": "^0.55.1",
    "mustache": "^4.2.0",
    "qs": "^6.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "sql-formatter": "^15.7.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-beautify": "^1.13.3",
    "@types/mustache": "^4.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^0.34.6",
    "cross-env": "^7.0.3",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.1",
    "sass": "^1.99.0",
    "typescript": "~5.8",
    "vite": "^6.4.2",
    "vitest": "^0.34.6"
  }
}
